---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { readingTime } from '../../utils/readingTime';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post, i) => ({
    params: { slug: post.slug },
    props: {
      post,
      prevPost: posts[i + 1] ?? null,
      nextPost: posts[i - 1] ?? null,
    },
  }));
}

const { post, prevPost, nextPost } = Astro.props;
const { Content } = await post.render();
---
<Layout
  title={post.data.title}
  description={post.data.description}
  type="article"
  publishedTime={post.data.date}
  articleTags={post.data.tags}
>
  <article class="rbd-article">
    <a href="/blog/" class="rbd-back">← writing</a>

    <div class="rbd-article-head">
      <div class="rbd-article-meta">
        <time datetime={post.data.date.toISOString()}>{post.data.date.toISOString().slice(0, 10)}</time>
        <span>{readingTime(post.body)}</span>
        {post.data.tags.length > 0 && (
          <span class="rbd-tags-row">
            {post.data.tags.map(tag => (
              <a href={`/blog/tags/${tag}/`} class="rbd-tag" style="text-decoration: none;">{tag}</a>
            ))}
          </span>
        )}
      </div>
      <h1 class="rbd-article-title">{post.data.title}</h1>
      <p class="rbd-article-dek">{post.data.description}</p>
    </div>

    <hr class="rbd-rule" />

    <div class="rbd-prose">
      <Content />
    </div>

    {(prevPost || nextPost) && (
      <nav class="rbd-post-nav" aria-label="Post navigation">
        {prevPost
          ? <a href={`/blog/posts/${prevPost.slug}/`} class="rbd-post-nav-prev" rel="prev">← {prevPost.data.title}</a>
          : <span />
        }
        {nextPost &&
          <a href={`/blog/posts/${nextPost.slug}/`} class="rbd-post-nav-next" rel="next">{nextPost.data.title} →</a>
        }
      </nav>
    )}

    <p class="rbd-sig">rbd</p>
  </article>
</Layout>

<script>
  import mermaid from 'mermaid';

  function getTheme() {
    return document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default';
  }

  function renderMermaid() {
    document.querySelectorAll('pre[data-language="mermaid"]').forEach(pre => {
      const code = pre.querySelector('code');
      const div = document.createElement('div');
      div.className = 'mermaid';
      div.textContent = code?.textContent ?? '';
      pre.replaceWith(div);
    });
    mermaid.initialize({ startOnLoad: false, theme: getTheme() });
    mermaid.run();
  }

  renderMermaid();

  document.getElementById('theme-toggle')?.addEventListener('click', () => {
    setTimeout(() => {
      document.querySelectorAll('.mermaid svg').forEach(svg => svg.parentElement?.removeAttribute('data-processed'));
      mermaid.initialize({ startOnLoad: false, theme: getTheme() });
      mermaid.run();
    }, 50);
  });
</script>

<style>
  .rbd-post-nav {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rbd-border, #e2e8f0);
    font-size: 0.875rem;
  }
  .rbd-post-nav-prev,
  .rbd-post-nav-next {
    color: inherit;
    text-decoration: none;
    max-width: 45%;
  }
  .rbd-post-nav-prev:hover,
  .rbd-post-nav-next:hover {
    text-decoration: underline;
  }
  .rbd-post-nav-next {
    margin-left: auto;
    text-align: right;
  }
  .mermaid {
    overflow-x: auto;
    margin: 1.5rem 0;
    text-align: center;
  }
</style>
